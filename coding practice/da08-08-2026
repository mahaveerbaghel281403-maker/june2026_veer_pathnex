## Ansible 
--- 
- name: Istall package from variable
  hosts: all
  become: yes

  vars:
    Pathnex_packages:
      - tree
      - unzip
      - vim
  tasks:
    - name: install packages
      yum:
        name: "{{ Pathnex_packages }}"
        state: present
## terraform

provider "aws" {
  region = "us-east-1"
}

resource "aws_vpc" "PathnexVpc" {
  cidr_block = "10.0.0.0/16	

  tags = {
    Name = "pathnex-Vpc"
  }
}

resource "aws_subnet" "Pathnex_Subnet" {
  vpc_id = aws_vpc.PathnexVpc.id
  cidr_block = "10.0.0.0/24
  map_public_ip_on_launch = true

  tags = {
    Name = "Pathnex-subnet"
  }
}

