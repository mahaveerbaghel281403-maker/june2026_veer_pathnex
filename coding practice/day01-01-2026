
#ANSIBLE TASKS:  ISTALL NGINX SEVER

---
- name: Install nginx on web server
  hosts: all
  become: yes
 
  tasks:
    - name: install nginx
      apt:
        name: nginx
        state: present


# TERRAFORM TASKS: Create ec2 (c5.xlarge)

provider "aws" {
  region = "us-east-1"
}

resource "aws_instance" "pathnexEc2" {
  ami  = "ami-vjhdhwcfhafhgf"
  instance_type = "c5.xlarge"
  
  tags = {
    Name = "pathnex-ec2"
  }
}

# kubernetes tasks: create nginx pod

apiVersion: v1
kind: pod
metadata:
  name: pathnex-pod
spec:
  containers:
    - name: web
      images: nginx:latest
      ports:
        - containerPort: 80
#Shell Script — Print Date & Hostname
#!/bin/bash
echo "Date: $(date)"
echo "Hostname: $(hostname)"

#git integration
## jenkins pipeline - checkout git

pipeline {
   agent any
   stages {
       stage('checkout') {
           steps {
               git branch: 'main' , url: 'https://github.com/pathnex/sample-java-app.git'
           }
       }
       stage('list files') {
           steps {
               sh 'ls -la'
           }
       }
    }
}

##git lab - checkout git
stages:
  - checkout

git-checkout:
  stage: checkout
  script:
    - git clone https://github.com/Pathnex/sample-java-app.git
    - cd sample-java-app
    - ls -la

