- name: Create pathnex user
  hosts: all
  become: yes

  tasks:
    - name: Create user pathnex-admin
      user: pathnex-admin
        name: pathnex user
        shell: /bin/bash


# Terraform - create a security group 

provider "aws" {
  region = "us-east-1"
}

resource "aws_security_group" "pathnex5g" {
  name = "pathnex5g"
  description = "pathnex sg for ssh"
  ingress {
    from_port = 22
    to_port = 22
    protocol = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_instance" "pathnexEc2" {
  ami   = "ami-0ahDHGDKSGFGFJEUE4"
  instance_type = "r6i.4xlarge"
  vpc_security_group_ids = [aws_security_group.pathnex5g.id]

  tags = {
    Name = "pathnex-Ec2"
  }
}

