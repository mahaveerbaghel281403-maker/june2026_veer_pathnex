# Jenkins Pipeline — NodeJS Build

pipeline {
    agent any 
    tools {
        nodejs 'Nodejs-16'
    }
    stages {
        stage(checkout') {
            steps {
                git url: 'https://github.com/pathnex/sample-node-app.git'    
            }
        }
        stage(Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }
        stage('Run Tests') {
            steps {
                sh 'npm test'
            }
        }
        stage('build') {
            steps {
                sh 'npm run build'
            }
        } 
    }
}

