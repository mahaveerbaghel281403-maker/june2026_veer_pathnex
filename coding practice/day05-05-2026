##  Kubernetes — Resource Limits

apiVersion:v1
kind: pod
metadata:
  name: limited pod
spec:
  containers:
    - name: app
      image: nginx
      resource:
        limits:
          memory: "256mi"
          cpu: "500m"

## jenkins - Environment variables


pipeline {
    agent any
    environment {
        INSTITUTE NAME = "pathnex"
    }
    stages {
        stage('print') {
            steps {
                sh 'echo "Welcome to $INSTITUTE_NAME Devops Training"'
            }
        }
        stage('build') {
            steps {
                sh 'mvn clean package -Dinstitute.name=$INSTITUTE_NAME'
            }
        }
    }
}

