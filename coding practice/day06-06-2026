## jenkins 

pipeline {
    agent any 
    stages {
        stage('checkout') {
            steps {
               git url: 'https://github.com/Pathnex/sample-java-app.git'
            }
        }
        stage('build') {
            steps {
                sh 'mvn clean compile'
            }
        }
        stage('test') {
            steps {
                sh 'mvn test'
            }
        }
    }
}
stages:
  - build
  - test
build:
  stage: build
  image: maven:3.8.1-jdk-17
  script:
    - git clone 'https://github.com/Pathnex/sample-java-app.git'
    - cd sample-java-app.git
    - mvn clean compile
test:
  stage: test
  image: maven:3.8.2-jdk-17
  script:
    - cd sample-java-app
    - mvn test 
