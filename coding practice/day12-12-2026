### jenkins

pipeline {
    agent any 
    environment {
        INSTITUTE_NAME = "pathnex"
    }
    stages {
         stage('checkout') {
             steps {
                 checkout scm
             }
         }
         stage('Build') {
             steps {
                 sh 'mvn clean compile'
             }
         }
    }
}

