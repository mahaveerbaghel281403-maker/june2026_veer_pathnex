## ansible

---
- name: Install java 
  hosts: all
  become: yes

  tasks:
    - name: Install openjdk
      yum:
        name: java-11-openjdk
        state: present
    - name: set JAVA_HOME
      lineinfile:
        path: /etc/profile
        line: 'export JAVA_HOME=/usr/lib/jvm/java-11-openjdk'

