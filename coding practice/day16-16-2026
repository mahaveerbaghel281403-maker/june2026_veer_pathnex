### jenkINS

pipeline {
    agent any
    environment {
        SCHOOL_NAME ="pathnex"
    }
    stages {
        stage('BUILD') {
            steps {
                sh 'mvn clean package'
            }
        }
        stage('Promote') {
            steps {
                input meassage: "Promote artifact to staging?"
                sh 'echo "Promoting artifacts for $SCHOOL_NAME"'
            }
        }
    }
}

