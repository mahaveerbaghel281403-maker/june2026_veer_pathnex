### kubernetes

apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: veer-db
spec:
  serviceName: "veer"
  replicas: 2
  selector:
    matchLabels:
      app: veer-db
  template:
    metadata:
      labels:
        app: veer-db
    spec:
      containers:
        - name: db
          image: mysql
          env:
            - name: MYSQL_ROOT_PASSWORD
              value: "Pathnex123"


