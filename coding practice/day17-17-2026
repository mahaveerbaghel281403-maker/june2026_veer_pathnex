### kubernetes

apiVersion: v1
kind: Namespace
metadata:
  name: dev


apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-deployment
  namespace: dev
spec:
  replicas:
  selector: 
    matchLabels:
      app: nginx
  template:
     metadata:
       labels:
         app: nginx
     spec:
       containers:
         - name: app
           image: nginx:latest

