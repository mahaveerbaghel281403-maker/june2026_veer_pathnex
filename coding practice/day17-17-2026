### ansible

---
- name: Create multiple user
  hosts: all
  become: yes

  vars:
    users:
      - dev1
      - dev2
      - dev3

  tasks:
    - name: create user
      user:
        name: "{{ item }}"
        state: present
      loop: "{{ user }}"


