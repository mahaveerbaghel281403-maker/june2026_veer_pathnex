## ansible
--- 
- name: show system fact
  hosts: all
  become: yes

  tasks:
    - name: Print os info
      debug:
        var: ansible_facts['os_family']

    - name: Print Ip address
      debug: 
        var: ansible_facts['default_ip4']['address']

