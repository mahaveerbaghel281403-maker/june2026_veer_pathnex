### kubernetes

apiVersion: apps/v1
kind: Deployment
metadata:
  name: roll-state
spec:
  replicas: 2
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 2
      maxUnavailable:1
  selector:
    matchLables:
      app: rollout
  template:
    metadata:
      labels:
        app: rollout
    spec:
      containers:
        - name: app
          image: nginx

