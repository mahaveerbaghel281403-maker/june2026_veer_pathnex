###  jenkins

pipeline {
    agent any
    environment {
        INSTITUTE_NAME: "pathnex"
    }
    stages {
        stage('deploy') {
            steps {
                input message: "approval deployment for $INSTITUTE_NAME?"
                sh 'echo "deployment is approved and executed"'
            }
        }
    }
}


