### ansible

---
- name: deploy app from git
  hosts: all
  become: yes

  tasks
    - name: install gitt
      yum:
        name: git
        state: present
    - name: Clone repository
      git:
        repo: "https://github.com/pathnex/app.git"
        dest: "/opt/pathnex-app"
