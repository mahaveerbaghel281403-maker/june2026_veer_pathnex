### kubernetes

apiVersion: apps/v1
kind: Deplooyment
metadata:
  name: nginx-deployment
spec:
  replicas: 3
  selector:
    matchLables:
      app: nginx
  template:
    metadata:
      lables:
        app: nginx
    spec:
      - name: nginx
        image: nginx:latest
        ports:
          - containerPort: 80

