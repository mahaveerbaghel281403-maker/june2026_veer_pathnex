### ansible
---
- name: configure nginx for pathnex
  hosts: all
  become: yes

  tasks:
    - name: copy nginx config
      copy:
        dest: /etc/nginx/nginx.conf
        content: |
          user nginx;
          worker_processes auto;
      notify: Restart nginx
  handlers:
    - name: REstart nginx
      service: 
        name: nginx
        state: restarted
