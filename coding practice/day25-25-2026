### jenkins

pipeline {
    agent any
    environment {
        INSTITUTE_NAME = "VEER"
        TEAM = "devops"
        ENV = "staging"
    }
    stages {
        stage('checkout') {
            steps {
                git url: 'https://github.com/pathnex/sample-java-app.git'
            }
        }
        stage('Build') {
            steps {
                sh '''
                if [ -d ".m2" ]; then
                    echo "Using chached dependencies for $INSTITUTE_NAME in $ENV by $TEAM"
                else 
                    mvn clean compile
                fi
                '''
            }
        }
    }
}

